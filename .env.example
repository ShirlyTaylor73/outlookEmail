# Flask 配置
# 必须设置！使用以下命令生成：python -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY=your-secret-key-here

# 登录密码（默认：admin123，首次启动后会自动哈希存储）
# 建议首次启动后立即通过 Web 界面修改为强密码（至少8位）
LOGIN_PASSWORD=admin123

# 应用配置
PORT=5000
HOST=0.0.0.0
FLASK_ENV=production

# 数据库路径
DATABASE_PATH=data/outlook_accounts.db

# GPTMail 临时邮箱配置
GPTMAIL_BASE_URL=https://mail.chatgpt.org.uk
GPTMAIL_API_KEY=gpt-test

# DuckMail 临时邮箱配置
DUCKMAIL_BASE_URL=https://api.duckmail.sbs
DUCKMAIL_API_KEY=

# iCloud Hide My Email (HME) 可选配置
# HME 地址需要先在 Web 界面配置接收源，接收源可使用 iCloud Mail、Gmail 或自定义 IMAP。
# 阶段 2 同步 HME 地址列表时，可在界面中配置 iCloud Cookie；请勿把真实密码或 Cookie 写入示例文件。

# OAuth2 配置（可选，不填使用默认值）
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_REDIRECT_URI=http://localhost:8080
